# Copy this file to .env and fill in real values. Never commit .env.

# Mealie API token (Mealie UI -> user settings -> create API token)
MEALIE_API_TOKEN=

# Override the mealie.url from config.yaml for local dev (outside Docker).
# Example: MEALIE_URL=http://localhost:9000
# Leave unset when running inside Docker (config.yaml value is used).
MEALIE_URL=

# Anthropic API key for the weekly LLM planning draft
ANTHROPIC_API_KEY=

# Telegram bot (message @BotFather on Telegram to create a bot + get this token)
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat id (message @userinfobot to get this)
TELEGRAM_CHAT_ID=

# Food Lion / Instacart storefront login (used once interactively to seed
# data/playwright_state.json, then the saved session is reused)
FOODLION_USERNAME=
FOODLION_PASSWORD=

# CapSolver API key for automatic Kasada bot-detection solving during cart builds.
# Get at capsolver.com -> Dashboard -> API Key. Leave unset to disable (falls back to
# the manual session-refresh Telegram alert when a Kasada challenge is detected).
CAPSOLVER_API_KEY=

# Uptime Kuma push-monitor URL for this job's healthcheck.
# Find it in Uptime Kuma: Monitors -> (create or pick a "Push" type monitor) -> Push URL.
# Looks like: http://<kuma-host>:<port>/api/push/<token>?status=up&msg=OK
UPTIME_KUMA_PUSH_URL=
